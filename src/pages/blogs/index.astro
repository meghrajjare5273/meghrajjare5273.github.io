---
// src/pages/blog/index.astro
import Layout from '@/layouts/Layout.astro';
import BlogList from '@/components/blogs/Section';
import { ProjectsPageOrchestrator } from '@/components/orchestrators/ProjectPageOrchestrator'
import { getBlogCards } from '@/lib/blog-content';

const posts = await getBlogCards();
---

<Layout
  title="Blog — Meghraj Jare"
  description="Thoughts on web development, AI/ML, and the craft of building great software."
>
  <ProjectsPageOrchestrator client:load >

    <BlogList client:load posts={posts} />
  </ProjectsPageOrchestrator>
</Layout>
