---
// src/pages/projects/[slug].astro
import { getCollection } from 'astro:content';
import ProjectLayout from '@/layouts/ProjectLayout.astro';
import { ProjectDetail } from '@/components/projects/ProjectDetail';
import { ProjectsPageOrchestrator } from '@/components/orchestrators/ProjectPageOrchestrator';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.data.slug || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const projectData = entry.data;
---

<ProjectLayout project={projectData}>
  <ProjectsPageOrchestrator client:load>
    <ProjectDetail project={projectData} client:load />
  </ProjectsPageOrchestrator>
</ProjectLayout>