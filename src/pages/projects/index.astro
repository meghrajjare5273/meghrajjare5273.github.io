---
import Layout from "@/layouts/Layout.astro";
import { ProjectsList } from "@/components/projects/ProjectsList";
import { ProjectsPageOrchestrator } from "@/components/orchestrators/ProjectPageOrchestrator";
import { getProjectCards } from "@/lib/project-content";

const projects = await getProjectCards();
---

<Layout title="Projects | Meghraj Jare">
  <ProjectsPageOrchestrator client:load>
    <ProjectsList client:load projects={projects} />
  </ProjectsPageOrchestrator>
</Layout>
