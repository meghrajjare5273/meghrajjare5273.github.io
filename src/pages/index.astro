---
import Layout from "../layouts/Layout.astro";
import { PageOrchestrator } from "@/components/orchestrators/PageOrchestrator";
import HeroSection from "@/components/landing/Hero";
import About from "@/components/landing/About";
import Footer from "@/components/landing/Footer";
import Contact from "@/components/landing/Contact";
---

<Layout>
  <PageOrchestrator client:load>
    <HeroSection client:load />
    <About client:visible={{rootMargin: "200px"}} />
    <Contact client:visible={{rootMargin: "200px"}} />
    <Footer client:visible={{rootMargin: "200px"}} />
  </PageOrchestrator>
</Layout>
