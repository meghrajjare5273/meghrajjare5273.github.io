---
import "@/styles/global.css";
import Navbar from "@/components/landing/Navbar";
import Footer from "@/components/landing/Footer";

// Import restructured components
import { ProjectHero } from "@/components/projects/dynamic/Hero";
import { ProjectInfo } from "@/components/projects/dynamic/ProjectInfo";
import { ProjectBackground } from "@/components/projects/dynamic/Background"; // Assume created
import { ProjectShowcase } from "@/components/projects/dynamic/Showcase"; // Assume created
import { ProjectChallenge } from "@/components/projects/dynamic/Challenge"; // Assume created
import { ProjectGallery } from "@/components/projects/dynamic/Gallery";
import {
  ProjectTechStack,
  type TeamMember,
} from "@/components/projects/dynamic/TechStack"; // Assume created
import { ProjectStats } from "@/components/projects/dynamic/Stats"; // Assume created
import { ProjectFooter } from "@/components/projects/dynamic/CTA"; // Assume created

// Define Props based on the NEW Schema
interface Props {
  data: {
    title: string;
    metadata: {
      industry: string;
      year: string;
      services: string;
      repoLink: string;
      deploymentLink?: string;
    };
    hero: {
      heading: string[];
      svgIcon?: string;
      image: string;
      imageAlt?: string;
    };
    background: {
      heading: string;
      text: string;
    };
    showcase: {
      videoSrc: string;
      thumbnail: string;
      alt: string;
    };
    challenge: {
      objective: string;
      detail: string;
    };
    gallery: {
      left: { image: string; description: string };
      right: { image: string; quote: string; description: string };
    };
    techStack: {
      heading: string;
      description: string;
      stack: string[];
      team: TeamMember[];
      roles: string[];
      teamImage: string;
    };
    stats: {
      heading: string;
      description: string;
      snapshotDate?: string; // Optional field for the specific date
      services: {
        name: string;
        status: "active" | "degraded" | "offline";
        description: string;
        updatedAt: string;
      }[];
    };
    testimonial: {
      quote: string;
      author: { image: string; name: string; role: string };
    };
  };
}

const { data } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{data.title}</title>
    <script is:inline transition:persist>
      // Prevent FOUC (Flash of Unstyled Content)
      (function () {
        const theme =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");

        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();

      // Reapply theme after view transitions
      document.addEventListener("astro:after-swap", () => {
        const theme =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");

        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      });

      let navigating = false;
      document.addEventListener("astro:before-preparation", () => {
        navigating = true;
        document.body.classList.add("navigating");
      });

      document.addEventListener("astro:page-load", () => {
        setTimeout(() => {
          navigating = false;
          document.body.classList.remove("navigating");
        }, 100);
      });

      // // Reset scroll position on navigation
      // if ("scrollRestoration" in window.history) {
      //   window.history.scrollRestoration = "manual";
      // }

      // Listen for Astro navigation events
      // document.addEventListener("astro:before-swap", () => {
      //   window.scrollTo(0, 0);
      // });

      document.addEventListener("astro:after-swap", (event) => {
        const detail = event.detail;
        if (!detail || !detail.to) return;

        const toPath = detail.to.pathname;

        // Only scroll to top when navigating to /projects or /projects/*
        if (toPath === "/projects" || toPath.startsWith("/projects/")) {
          // Use requestAnimationFrame to ensure DOM is ready
          requestAnimationFrame(() => {
            window.scrollTo({ top: 0, left: 0, behavior: "instant" });
            // Force a layout recalculation
            document.body.offsetHeight;
          });
        }
      });
    </script>
  </head>
  <body>
    <main
      class="w-full min-h-dvh pt-[120px] md:pt-[150px] flex flex-col gap-12 md:gap-20 bg-[#eceae8] dark:bg-[#0e0e0e] overflow-x-hidden"
    >
      <Navbar client:load />

      <ProjectHero
        titleLines={data.hero.heading}
        svgIcon={data.hero.svgIcon}
        image={data.hero.image}
        imageAlt={data.hero.imageAlt}
        client:load
      />

      <ProjectInfo
        industry={data.metadata.industry}
        year={data.metadata.year}
        services={data.metadata.services}
        repoLink={data.metadata.repoLink}
        deploymentLink={data.metadata.deploymentLink}
        client:load
      />

      <ProjectBackground
        heading={data.background.heading}
        text={data.background.text}
        client:load
      />

      <ProjectShowcase
        videoSrc={data.showcase.videoSrc}
        thumbnail={data.showcase.thumbnail}
        alt={data.showcase.alt}
        client:load
      />

      <ProjectChallenge
        objective={data.challenge.objective}
        detail={data.challenge.detail}
        client:load
      />

      <ProjectGallery
        left={data.gallery.left}
        right={data.gallery.right}
        client:load
      />

      <ProjectTechStack
        heading={data.techStack.heading}
        description={data.techStack.description}
        stack={data.techStack.stack}
        team={data.techStack.team}
        teamImage={data.techStack.teamImage}
        client:load
      />

      <ProjectStats
        heading={data.stats.heading}
        description={data.stats.description}
        services={data.stats.services}
        snapshotDate={data.stats.snapshotDate}
        client:load
      />

      <ProjectFooter
        quote={data.testimonial.quote}
        author={data.testimonial.author}
        ctaLink="#contact"
        client:load
      />

      <Footer client:load />
    </main>
  </body>
</html>
