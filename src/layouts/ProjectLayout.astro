---
import { HeroSection } from '@/components/projects/dynamic/Hero';
import { ProjectInfoGrid } from '@/components/projects/dynamic/ProjectInfo';

// src/layouts/ProjectLayout.astro


// Define Props interface for direct data passing
interface Props {
  data: {
    title: string;
    industry: string;
    year: string;
    services: string;
    background: {
      heading: string;
      text: string;
    };
    challenge: {
      objective: string;
      detail: string;
    };
    hero: {
      title: string[];
      tag?: string;
      image: string;
      imageAlt?: string;
    };
    video: {
      image: string;
      imageAlt: string;
    };
    gravityImages: {
      left: {
        image: string;
        caption: string;
      };
      right: {
        image: string;
        quote: string;
      };
    };
    techStack: {
      heading: string;
      description: string;
      stack: string[];
      team: string[];
      roles: string[];
      teamImage: string;
    };
    stats: {
      resultTitle: string;
      resultDescription: string;
      items: {
        number: number;
        suffix?: string;
        description: string;
      }[];
    };
    footer: {
      quote: string;
      avatar: {
        image: string;
        name: string;
        title: string;
      };
    };
  };
}

const { data } = Astro.props;
---

<main class="w-full min-h-screen pt-[120px] md:pt-[150px] pb-[100px] flex flex-col gap-12 md:gap-20 bg-[#eceae8] dark:bg-[#0e0e0e] overflow-x-hidden selection:bg-orange-500/30">
  <HeroSection
    title={data.hero.title}
    tag={data.hero.tag}
    image={data.hero.image}
    imageAlt={data.hero.imageAlt}
  />
  <ProjectInfoGrid
    industry={data.industry}
    year={data.year}
    services={data.services}
  />
