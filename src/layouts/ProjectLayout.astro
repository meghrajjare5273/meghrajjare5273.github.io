---
import "@/styles/global.css";
import Navbar from "@/components/landing/Navbar";
import Footer from "@/components/landing/Footer";

// Import restructured components
import { ProjectHero } from "@/components/projects/dynamic/Hero";
import { ProjectInfo } from "@/components/projects/dynamic/ProjectInfo";
import { ProjectBackground } from "@/components/projects/dynamic/Background"; // Assume created
import { ProjectShowcase } from "@/components/projects/dynamic/Showcase";   // Assume created
import { ProjectChallenge } from "@/components/projects/dynamic/Challenge"; // Assume created
import { ProjectGallery } from "@/components/projects/dynamic/Gallery";
import { ProjectTechStack } from "@/components/projects/dynamic/TechStack"; // Assume created
import { ProjectStats } from "@/components/projects/dynamic/Stats";         // Assume created
import { ProjectFooter } from "@/components/projects/dynamic/CTA";       // Assume created

// Define Props based on the NEW Schema
interface Props {
  data: {
    title: string;
    metadata: {
      industry: string;
      year: string;
      services: string;
    };
    hero: {
      heading: string[];
      tag?: string;
      image: string;
      imageAlt?: string;
    };
    background: {
      heading: string;
      text: string;
    };
    showcase: {
      image: string;
      imageAlt: string;
    };
    challenge: {
      objective: string;
      detail: string;
    };
    gallery: {
      left: { image: string; caption: string };
      right: { image: string; quote: string };
    };
    techStack: {
      heading: string;
      description: string;
      stack: string[];
      team: string[];
      roles: string[];
      teamImage: string;
    };
    stats: {
      heading: string;
      description: string;
      items: { value: number; suffix?: string; label: string }[];
    };
    testimonial: {
      quote: string;
      author: { image: string; name: string; role: string };
    };
  };
}

const { data } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{data.title}</title>
    </head>
  <body>
    <main class="w-full min-h-dvh pt-[120px] md:pt-[150px] flex flex-col gap-12 md:gap-20 bg-[#eceae8] dark:bg-[#0e0e0e] overflow-x-hidden">
      <Navbar client:load />
      
      <ProjectHero
        titleLines={data.hero.heading}
        tag={data.hero.tag}
        image={data.hero.image}
        imageAlt={data.hero.imageAlt}
        client:load
      />

      <ProjectInfo
        industry={data.metadata.industry}
        year={data.metadata.year}
        services={data.metadata.services}
        client:load
      />

      <ProjectBackground
        heading={data.background.heading}
        text={data.background.text}
        client:load
      />

      <ProjectShowcase
        image={data.showcase.image}
        alt={data.showcase.imageAlt}
        client:load
      />

      <ProjectChallenge
        objective={data.challenge.objective}
        detail={data.challenge.detail}
        client:load
      />

      <ProjectGallery
        left={data.gallery.left}
        right={data.gallery.right}
        client:load
      />

      <ProjectTechStack
        heading={data.techStack.heading}
        description={data.techStack.description}
        stack={data.techStack.stack}
        team={data.techStack.team}
        roles={data.techStack.roles}
        teamImage={data.techStack.teamImage}
        client:load
      />

      <ProjectStats
        heading={data.stats.heading}
        description={data.stats.description}
        items={data.stats.items}
        client:load
      />

      <ProjectFooter
        quote={data.testimonial.quote}
        author={data.testimonial.author}
        ctaLink="#contact"
        client:load
      />

      <Footer client:load />
    </main>
  </body>
</html>