---
// src/layouts/ProjectLayout.astro
import Layout from "./Layout.astro";
import Navbar from "@/components/landing/Navbar";
import Footer from "@/components/landing/Footer";
import type { ProjectDetailData } from "@/lib/project-content";

interface Props {
  project: ProjectDetailData;
}

const { project } = Astro.props;

// Construct dynamic SEO tags based on project data
const seoDescription = project.tagline || project.description.substring(0, 160);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<Layout 
  title={`${project.title} | Meghraj Jare`} 
  description={seoDescription}
>
  <slot name="seo-meta" slot="head">
    <meta property="og:title" content={`${project.title} | Meghraj Jare`} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(project.thumbnail, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />
  </slot>

  <Navbar client:load />
  
  <main>
    <slot />
  </main>

  <Footer client:visible />
</Layout>