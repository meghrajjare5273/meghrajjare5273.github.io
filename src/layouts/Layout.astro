---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import DocumentClientSetup from "@/layouts/DocumentClientSetup.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>Meghraj Jare</title>

    <ClientRouter />

    <link
      rel="preload"
      href="https://cdn.jsdelivr.net/npm/@fontsource-variable/space-grotesk@5.2.10/files/space-grotesk-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <DocumentClientSetup />
  </head>
  <body>
    <div
      class="fixed inset-0 z-9999 pointer-events-none opacity-[0.03] mix-blend-overlay"
      style="background-image: url('https://grainy-gradients.vercel.app/noise.svg');"
    >
    </div>
    <slot />
  </body>
</html>
