---
// src/layouts/BlogLayout.astro
import Layout from './Layout.astro';
import Navbar from '../components/landing/Navbar';
import Footer from '../components/landing/Footer';
import type { BlogPostData } from '../lib/blog-content';
import { formatDate } from '../lib/blog-content';

interface MarkdownHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: BlogPostData;
  headings?: MarkdownHeading[];
}

const { post, headings = [] } = Astro.props;

const seoDescription = post.description.substring(0, 160);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<Layout
  title={`${post.title} — Meghraj Jare`}
  description={seoDescription}
  image={post.thumbnail}
>
  <slot name="seo-meta" slot="seo-meta">
    <meta property="og:title" content={`${post.title} — Meghraj Jare`} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    {post.thumbnail && <meta property="og:image" content={new URL(post.thumbnail, Astro.site)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />
  </slot>

  <main class="min-h-screen bg-[#eceae8] dark:bg-[#0a0a0a] text-foreground">
    <!-- Sticky Navbar -->
    <div class="fixed top-0 left-0 right-0 z-50 bg-[#eceae8]/80 dark:bg-[#0a0a0a]/80 backdrop-blur-md">
      <Navbar client:load />
    </div>

    <!-- Hero Header -->
    <header class="w-full max-w-[900px] mx-auto px-6 md:px-10 pt-36 pb-12">
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-6">
        {post.tags.map((tag) => (
          <span class="text-xs font-space uppercase tracking-widest px-3 py-1 border border-neutral-400/40 dark:border-neutral-600/40 rounded-full text-neutral-500 dark:text-neutral-400">
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="font-about-complement text-4xl md:text-6xl lg:text-7xl leading-[1.0] tracking-tight mb-6">
        {post.title}
      </h1>

      <!-- Description -->
      <p class="text-lg md:text-xl text-neutral-500 dark:text-neutral-400 font-about max-w-[65ch] mb-10">
        {post.description}
      </p>

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-x-8 gap-y-2 text-sm text-neutral-500 dark:text-neutral-400 font-space border-t border-black/10 dark:border-white/10 pt-6">
        <span>{post.author}</span>
        <time datetime={post.pubDate.toISOString()}>
          {formatDate(post.pubDate)}
        </time>
        {post.readTime && <span>{post.readTime} min read</span>}
        {post.updatedDate && (
          <span class="text-neutral-400 dark:text-neutral-600 text-xs">
            Updated {formatDate(post.updatedDate)}
          </span>
        )}
      </div>

      <!-- Thumbnail -->
      {post.thumbnail && (
        <div class="mt-10 w-full aspect-video overflow-hidden rounded-2xl">
          <img
            src={post.thumbnail}
            alt={post.title}
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      )}
    </header>

    <!-- MDX Content via <slot /> -->
    <article class="
      w-full max-w-[720px] mx-auto px-6 md:px-10 pb-32
      prose prose-neutral dark:prose-invert
      prose-headings:font-about-complement prose-headings:tracking-tight
      prose-h2:text-3xl prose-h3:text-2xl
      prose-p:font-about prose-p:leading-relaxed prose-p:text-base md:prose-p:text-lg
      prose-a:text-foreground prose-a:underline prose-a:underline-offset-4
      prose-code:font-mono prose-code:text-sm
      prose-pre:rounded-xl prose-pre:bg-neutral-100 dark:prose-pre:bg-neutral-900
      prose-blockquote:border-l-foreground prose-blockquote:font-about prose-blockquote:not-italic
      prose-img:rounded-xl prose-img:w-full
      prose-hr:border-black/10 dark:prose-hr:border-white/10
    ">
      <slot />
    </article>

    <!-- Table of Contents (optional sidebar on large screens) -->
    {headings.length > 2 && (
      <aside class="hidden xl:block fixed right-8 top-1/3 w-52 text-xs font-space">
        <p class="uppercase tracking-widest text-neutral-400 mb-3">On this page</p>
        <ul class="space-y-2">
          {headings
            .filter((h) => h.depth <= 3)
            .map((h) => (
              <li style={{ paddingLeft: `${(h.depth - 2) * 12}px` }}>
                <a
                  href={`#${h.slug}`}
                  class="text-neutral-500 dark:text-neutral-400 hover:text-foreground transition-colors duration-200 line-clamp-2"
                >
                  {h.text}
                </a>
              </li>
            ))}
        </ul>
      </aside>
    )}

    <Footer client:visible={{rootMargin: "200px"}} />
  </main>
</Layout>
